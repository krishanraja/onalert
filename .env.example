# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe (required for payments)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App URL (used for auth redirects + canonical/share URLs)
VITE_APP_URL=https://onalert.app

# === SUPABASE EDGE FUNCTION SECRETS (server-side only) ===
# These do NOT belong in any VITE_* var or in the client bundle.
# Set them via:  supabase secrets set --env-file=path/to/secrets
# or in the Supabase dashboard under Edge Functions > Secrets.
#
#   SUPABASE_SERVICE_ROLE_KEY  - already managed by Supabase
#   STRIPE_SECRET_KEY          - sk_live_... / sk_test_...
#   STRIPE_WEBHOOK_SECRET      - whsec_...
#   RESEND_API_KEY             - re_...
#   TWILIO_ACCOUNT_SID         - AC...
#   TWILIO_AUTH_TOKEN          - ...
#   TWILIO_FROM_NUMBER         - +1...
#   CRON_SECRET                - random; required for cron-only fns (poll-appointments, etc.)
#   INTERNAL_FUNCTION_SECRET   - random; required for internal-only fns (send-alert, send-push, etc.)
#   VAPID_PUBLIC_KEY           - Web Push VAPID public key; used by send-push
#   VAPID_PRIVATE_KEY          - Web Push VAPID private key; used by send-push
#   APP_URL                    - server-side base URL; used by create-checkout / customer-portal for redirect URLs
